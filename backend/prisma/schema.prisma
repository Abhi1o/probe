// Probe Platform - Database Schema
// PostgreSQL + TimescaleDB for time-series data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User Management
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  programs      Program[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]
  notifications Notification[]

  @@map("users")
}

enum Role {
  USER
  ADMIN
  DEVELOPER
}

// Solana Programs
model Program {
  id            String   @id @default(uuid())
  userId        String
  programId     String   @unique
  name          String
  description   String?
  network       Network
  repositoryUrl String?
  isActive      Boolean  @default(true)
  
  // Ownership Verification Fields
  ownerWallet           String?
  upgradeAuthority      String?
  verificationMethod    String?
  verifiedAt            DateTime?
  verificationDetails   String?
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  alerts       Alert[]
  metrics      Metric[]
  instructionCallRecords    InstructionCallRecord[]
  instructionHourlyAggregates InstructionHourlyAggregate[]
  healthScore               ProgramHealthScore?

  @@index([userId])
  @@index([programId])
  @@index([network])
  @@map("programs")
}

enum Network {
  MAINNET_BETA
  DEVNET
  TESTNET
}

// Transactions (TimescaleDB Hypertable)
model Transaction {
  id           BigInt   @id @default(autoincrement())
  programId    String
  signature    String   // Removed @unique for TimescaleDB compatibility
  slot         BigInt
  blockTime    DateTime
  blockDateUtc DateTime @db.Date
  status       TxStatus
  fee          BigInt
  computeUnits Int?
  signer       String
  instructions Json?
  logs         String[]
  error        String?
  rawData      Json?
  indexedAt    DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, blockTime(sort: Desc)])
  @@index([signature])
  @@index([signer, blockTime(sort: Desc)])
  @@index([status])
  @@index([blockDateUtc])
  @@map("transactions")
}

enum TxStatus {
  SUCCESS
  FAILED
  PENDING
}

// Metrics (TimescaleDB Continuous Aggregates)
model Metric {
  id        BigInt   @id @default(autoincrement())
  programId String
  timestamp DateTime
  hour      DateTime @db.Timestamptz
  txCount   Int      @default(0)
  successCount Int   @default(0)
  failureCount Int   @default(0)
  avgComputeUnits Float?
  avgFee    Float?
  medianComputeUnits Float?
  createdAt DateTime @default(now())

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, hour(sort: Desc)])
  @@map("metrics")
}

// Alerts
model Alert {
  id          String        @id @default(uuid())
  programId   String
  name        String
  description String?
  condition   AlertCondition
  threshold   Float
  comparison  Comparison
  channels    Channel[]
  cooldown    Int           @default(300) // seconds
  enabled     Boolean       @default(true)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  program  Program        @relation(fields: [programId], references: [id], onDelete: Cascade)
  triggers AlertTrigger[]

  @@index([programId])
  @@index([enabled])
  @@map("alerts")
}

enum AlertCondition {
  TRANSACTION_FAILURE_RATE
  COMPUTE_UNITS_EXCEEDED
  TRANSACTION_COUNT_THRESHOLD
  CUSTOM_METRIC
}

enum Comparison {
  GREATER_THAN
  LESS_THAN
  EQUAL_TO
}

enum Channel {
  EMAIL
  SLACK
  DISCORD
  WEBHOOK
}

// Alert Triggers
model AlertTrigger {
  id          String   @id @default(uuid())
  alertId     String
  triggeredAt DateTime @default(now())
  value       Float
  notified    Boolean  @default(false)
  notifiedAt  DateTime?

  alert Alert @relation(fields: [alertId], references: [id], onDelete: Cascade)

  @@index([alertId, triggeredAt(sort: Desc)])
  @@map("alert_triggers")
}

// API Keys
model ApiKey {
  id        String   @id @default(uuid())
  userId    String
  key       String   @unique
  name      String
  expiresAt DateTime?
  lastUsed  DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

// Audit Logs
model AuditLog {
  id        BigInt   @id @default(autoincrement())
  userId    String
  action    String
  resource  String
  details   Json?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([action])
  @@map("audit_logs")
}

// Notifications
model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([read])
  @@map("notifications")
}

enum NotificationType {
  ALERT
  INFO
  WARNING
  ERROR
}

// ─── Instruction Analytics (Feature: Contract Method Analytics) ───────────────
// Per-instruction call records — the "Alchemy Monitor per-method" for Solana programs
model InstructionCallRecord {
  id                      BigInt   @id @default(autoincrement())
  programId               String
  environment             String   @default("DEVNET")

  // Instruction identity (decoded from IDL or discriminator)
  instructionName         String?  // null if IDL not uploaded
  instructionDiscriminator String? // 8-byte hex anchor discriminator
  displayName             String?  // user-friendly override

  // Transaction reference
  signature               String
  slot                    BigInt
  blockTime               DateTime

  // Outcome
  success                 Boolean
  errorCode               String?  // Anchor error code (e.g. "6003") or system error
  errorName               String?  // Human-readable from IDL (e.g. "SlippageExceeded")
  errorMessage            String?  // Full error message
  errorCategory           String?  // business_logic | access_control | validation | math | state | external | system

  // Performance
  computeUnitsUsed        Int?
  computeUnitsRequested   Int?     // From ComputeBudget instruction
  feeLamports             BigInt?
  priorityFeeLamports     BigInt?

  // Caller
  callerWallet            String?  // First signer
  callerType              String?  // bot | whale | smart_money | retail

  // Arguments (JSON — decoded from IDL)
  decodedArgs             Json?

  // Events emitted by this instruction
  emittedEvents           Json?

  // CPI context
  cpiCount                Int      @default(0)
  involvedPrograms        String[]

  timestamp               DateTime

  program                 Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId, instructionName, timestamp(sort: Desc)])
  @@index([programId, success, timestamp(sort: Desc)])
  @@index([programId, errorCode, timestamp(sort: Desc)])
  @@index([callerWallet, programId, timestamp(sort: Desc)])
  @@index([signature])
  @@map("instruction_call_records")
}

// Hourly aggregate for fast dashboard queries
model InstructionHourlyAggregate {
  id               BigInt   @id @default(autoincrement())
  programId        String
  instructionName  String
  environment      String   @default("DEVNET")
  bucket           DateTime // time_bucket('1 hour', timestamp)

  callCount        Int      @default(0)
  successCount     Int      @default(0)
  failureCount     Int      @default(0)
  errorRate        Float    @default(0)
  successRate      Float    @default(0)

  avgComputeUnits  Int?
  p50ComputeUnits  Int?
  p95ComputeUnits  Int?

  uniqueCallers    Int      @default(0)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  program          Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, instructionName, environment, bucket])
  @@index([programId, bucket(sort: Desc)])
  @@map("instruction_hourly_aggregates")
}

// AI-generated error explanations cache
model ErrorExplanationCache {
  id              BigInt   @id @default(autoincrement())
  programId       String
  instructionName String
  errorCode       String
  explanation     String
  fixSuggestion   String
  generatedAt     DateTime @default(now())
  expiresAt       DateTime

  @@unique([programId, instructionName, errorCode])
  @@map("error_explanation_cache")
}

// ─── Program Health Score ─────────────────────────────────────────────────────
// Computed health score for each program — updated every 5 minutes
model ProgramHealthScore {
  id                    String   @id @default(uuid())
  programId             String   @unique

  // Overall score (0-100)
  score                 Int      // 0-100
  grade                 String   // A+ A B C D F
  trend                 String   // improving | stable | declining

  // Component scores (each 0-100)
  reliabilityScore      Int      // Based on success rate
  performanceScore      Int      // Based on compute units vs budget
  activityScore         Int      // Based on transaction volume trend
  errorScore            Int      // Based on error rate and diversity
  userScore             Int      // Based on unique users and retention

  // Raw metrics used for scoring
  successRate24h        Float
  successRate7d         Float
  avgComputeUnits24h    Float
  errorRate24h          Float
  txCount24h            Int
  txCount7d             Int
  uniqueUsers24h        Int
  uniqueUsers7d         Int
  topErrorCode          String?
  topErrorCount         Int      @default(0)

  // Insights
  strengths             String[] // e.g. ["High success rate", "Low compute usage"]
  warnings              String[] // e.g. ["Error rate increased 15% today"]
  recommendations       String[] // e.g. ["Consider optimizing compute units"]

  computedAt            DateTime @default(now())
  updatedAt             DateTime @updatedAt

  program               Program  @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@map("program_health_scores")
}

// ─── CPI (Cross-Program Invocation) Analysis ─────────────────────────────────
// Tracks which programs call which other programs — unique Solana-native feature
model CpiEdge {
  id                String   @id @default(uuid())

  // The calling program (monitored by Probe)
  callerProgramId   String
  callerLabel       String   @default("Unknown")

  // The called program
  calleeProgramId   String
  calleeLabel       String   @default("Unknown")

  // Aggregate stats (updated on each new transaction)
  invocationCount   Int      @default(0)
  successCount      Int      @default(0)
  failureCount      Int      @default(0)
  avgComputeUnits   Float    @default(0)
  maxDepth          Int      @default(1)   // Max CPI nesting depth seen
  lastInvoked       DateTime @default(now())

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([callerProgramId, calleeProgramId])
  @@index([callerProgramId])
  @@index([calleeProgramId])
  @@map("cpi_edges")
}

// ─── Wallet Intelligence ──────────────────────────────────────────────────────
// Basic wallet classification derived from on-chain behavior
model WalletProfile {
  address           String   @id

  // Classification
  primaryLabel      String   @default("retail")  // bot | whale | smart_money | retail | fresh | dormant
  isBot             Boolean  @default(false)
  isWhale           Boolean  @default(false)
  isSmartMoney      Boolean  @default(false)
  isFresh           Boolean  @default(false)
  isDormant         Boolean  @default(false)

  // Behavioral stats (computed from transactions)
  totalTxCount      Int      @default(0)
  successRate       Float    @default(0)
  avgTxPerDay       Float    @default(0)
  firstSeenAt       DateTime?
  lastSeenAt        DateTime?

  // Program-specific stats (JSON: { programId: { txCount, successRate, fees } })
  programStats      Json?

  updatedAt         DateTime @updatedAt

  @@map("wallet_profiles")
}

// ─── MEV Detection ────────────────────────────────────────────────────────────
model MevEvent {
  id                String   @id @default(uuid())
  programId         String
  mevType           String   // sandwich | frontrun | backrun | arbitrage | jit_liquidity
  severity          String   // low | medium | high | critical

  // Transaction signatures involved
  victimSignature   String?
  attackerSignature String?
  relatedSignatures String[]

  // Wallets
  attackerWallet    String?
  victimWallet      String?

  // Financial impact
  estimatedLostLamports  BigInt   @default(0)
  estimatedProfitLamports BigInt  @default(0)

  // Context
  slot              BigInt?
  detectedAt        DateTime @default(now())
  description       String?

  @@index([programId, detectedAt(sort: Desc)])
  @@index([attackerWallet])
  @@index([mevType])
  @@map("mev_events")
}
