NODE_ENV=production
PORT=3000

# Database
DATABASE_URL=postgresql://user:password@host:5432/probe

# Redis
# Railway Redis usually provides REDIS_URL automatically.
REDIS_URL=redis://default:password@host:6379
# Optional fallback if REDIS_URL is not used:
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false

# Auth
JWT_SECRET=replace-with-a-long-random-secret
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Solana
SOLANA_NETWORK=devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_WS_URL=wss://api.devnet.solana.com

# Optional notifications
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASSWORD=
SMTP_SECURE=false
SMTP_FROM_NAME=Probe Platform
SMTP_FROM_EMAIL=noreply@probe.dev
SLACK_WEBHOOK_URL=
SLACK_CHANNEL=#probe-alerts
SLACK_USERNAME=Probe Bot
SLACK_ICON_EMOJI=:robot_face:
DISCORD_WEBHOOK_URL=
DISCORD_USERNAME=Probe Bot
DISCORD_AVATAR_URL=
